---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
  class?: string;
}

const {
  eyebrow,
  title,
  description,
  align = "left",
  class: className,
} = Astro.props as Props;

const isCenter = align === "center";
---

<div class:list={["mb-8", isCenter && "text-center mx-auto", className]}>
  {eyebrow && <p class="mb-2 text-sm font-medium text-navy/70">{eyebrow}</p>}
  <h2 class="text-2xl font-semibold tracking-tight text-navy md:text-3xl">{title}</h2>
  {
    description && (
      <p class:list={["mt-3 max-w-2xl text-navy/70", isCenter && "mx-auto"]}>
        {description}
      </p>
    )
  }
</div>

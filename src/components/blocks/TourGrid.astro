---
import Container from "../ui/Container.astro";
import SectionHeading from "../ui/SectionHeading.astro";
import TourCard from "./TourCard.astro";

interface TourItem {
  title: string;
  imageSrc: string;
  imageAlt: string;
  description?: string;
  price?: string;
  href: string;
}

interface Props {
  title?: string;
  eyebrow?: string;
  description?: string;
  tours: TourItem[];
  class?: string;
}

const { title, eyebrow, description, tours, class: className } = Astro.props as Props;
---

<section class:list={["py-16 md:py-20", className]}>
  <Container>
    {title && <SectionHeading eyebrow={eyebrow} title={title} description={description} />}

    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {tours.map((tour) => <TourCard {...tour} />)}
    </div>
  </Container>
</section>

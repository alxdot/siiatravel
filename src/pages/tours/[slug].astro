---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sanityClient, urlFor } from "../../lib/sanity";
import PortableTextRenderer from "../../components/PortableTextRenderer";
import { buildReviewsJsonLd, stringifyJsonLd } from "../../lib/seo/reviews-jsonld";


export async function getStaticPaths() {
  const slugs: { slug: { current: string } }[] = await sanityClient.fetch(`
    *[_type == "tour" && defined(slug.current)]{ slug }
  `);

  return slugs.map((t) => ({
    params: { slug: t.slug.current },
  }));
}

type Tour = {
  _id: string;
  title: string;
  excerpt?: string;
  heroImage?: any;
  priceFromEur?: number;
  durationHours?: number;
  format?: "walking" | "car" | "mixed";
  content?: any[];
};

const { slug } = Astro.params;

const tour: Tour | null = await sanityClient.fetch(
  `
  *[_type == "tour" && slug.current == $slug][0]{
    _id,
    title,
    excerpt,
    heroImage,
    priceFromEur,
    durationHours,
    format,
    content
  }
`,
  { slug }
);

if (!tour) {
  return Astro.redirect("/404");
}

type RawTourReview = {
  name?: unknown;
  rating?: unknown;
  text?: unknown;
  date?: unknown;
};

type NormalizedReview = {
  name: string;
  rating: number;
  text: string;
  dateISO: string | null;
};

function isNonEmptyString(v: unknown): v is string {
  return typeof v === "string" && v.trim().length > 0;
}

function parseRating(v: unknown): number | null {
  let numericValue: number;

  if (typeof v === "number") {
    numericValue = v;
  } else if (typeof v === "string") {
    const trimmed = v.trim();
    if (trimmed.length === 0) return null;
    numericValue = Number(trimmed);
  } else {
    return null;
  }

  if (!Number.isInteger(numericValue)) return null;
  if (numericValue < 1 || numericValue > 5) return null;
  return numericValue;
}

function normalizeDateISO(v: unknown): string | null {
  if (typeof v !== "string") return null;
  const trimmed = v.trim();
  if (trimmed.length === 0) return null;
  return Number.isNaN(Date.parse(trimmed)) ? null : trimmed;
}

const rawApprovedTourReviews: RawTourReview[] = await sanityClient.fetch(
  `
  *[_type == "review" && status == "approved" && subjectType == "tour" && tour._ref == $tourId]
    | order(date desc)[0...10]{
      name,
      rating,
      text,
      date
    }
`,
  { tourId: tour._id }
);

const approvedTourReviews: NormalizedReview[] = rawApprovedTourReviews
  .map((review): NormalizedReview | null => {
    if (!isNonEmptyString(review.name) || !isNonEmptyString(review.text)) return null;

    const rating = parseRating(review.rating);
    if (rating === null) return null;

    return {
      name: review.name.trim(),
      rating,
      text: review.text.trim(),
      dateISO: normalizeDateISO(review.date),
    };
  })
  .filter((review): review is NormalizedReview => review !== null);

const reviewCount = approvedTourReviews.length;
const averageRating =
  reviewCount > 0
    ? approvedTourReviews.reduce((sum, review) => sum + review.rating, 0) / reviewCount
    : 0;
const visibleAverageRating = averageRating.toFixed(1);
const reviewDateFormatter = new Intl.DateTimeFormat("ru-RU", {
  day: "2-digit",
  month: "2-digit",
  year: "numeric",
});

function renderStars(rating: number): string {
  return `${"★".repeat(rating)}${"☆".repeat(5 - rating)}`;
}

function formatReviewDate(dateISO: string | null): string | null {
  if (!dateISO) return null;
  const parsed = new Date(dateISO);
  if (Number.isNaN(parsed.getTime())) return null;
  return reviewDateFormatter.format(parsed);
}

const siteOrigin = (Astro.site?.toString() ?? Astro.url.origin).replace(/\/$/, "");
const tourUrl = `${siteOrigin}/tours/${slug}`;
const tourImage = tour.heroImage ? urlFor(tour.heroImage).width(1200).url() : undefined;
const reviewsJsonLdBase = buildReviewsJsonLd({
  name: tour.title,
  url: tourUrl,
  ...(tourImage ? { image: tourImage } : {}),
  ...(tour.excerpt ? { description: tour.excerpt } : {}),
  aggregate: {
    ratingValue: averageRating,
    reviewCount,
  },
});
const reviewsJsonLd =
  reviewsJsonLdBase && approvedTourReviews.length > 0
    ? {
        ...reviewsJsonLdBase,
        review: approvedTourReviews.map((review) => ({
          "@type": "Review",
          author: { "@type": "Person", name: review.name },
          reviewRating: {
            "@type": "Rating",
            ratingValue: review.rating,
            bestRating: 5,
            worstRating: 1,
          },
          reviewBody: review.text,
          ...(review.dateISO ? { datePublished: review.dateISO } : {}),
        })),
      }
    : reviewsJsonLdBase;
---

<BaseLayout>
  <Fragment slot="head">
    <title>{tour.title} — Siiatravel</title>
    {tour.excerpt && <meta name="description" content={tour.excerpt} />}
    {reviewsJsonLd && (
      <script type="application/ld+json" set:html={stringifyJsonLd(reviewsJsonLd)} />
    )}
  </Fragment>

  <section class="max-w-4xl mx-auto px-4 py-16">
    <a href="/tours" class="text-sm text-navy/70 hover:underline">← Все экскурсии</a>

    <h1 class="text-3xl md:text-4xl font-semibold text-navy mt-4">{tour.title}</h1>

    {reviewCount > 0 && (
      <p class="mt-3 text-sm text-navy/80">
        Рейтинг по отзывам: <strong class="text-navy">{visibleAverageRating}</strong>/5 ({reviewCount})
      </p>
    )}

    <div class="text-sm text-navy/80 mt-4 flex flex-wrap gap-x-4 gap-y-1">
      {typeof tour.priceFromEur === "number" && (
        <span>
          <strong class="text-navy">от {tour.priceFromEur} €</strong>
        </span>
      )}
      {typeof tour.durationHours === "number" && <span>{tour.durationHours} ч</span>}
      {tour.format && (
        <span>
          {tour.format === "walking"
            ? "пешая"
            : tour.format === "car"
              ? "с машиной"
              : "смешанная"}
        </span>
      )}
    </div>

    {tour.heroImage && (
      <img
        src={urlFor(tour.heroImage).width(1200).height(700).fit("crop").url()}
        alt={tour.title}
        loading="eager"
        class="w-full rounded-2xl mt-8 object-cover"
      />
    )}

    {tour.excerpt && <p class="text-navy/80 text-lg mt-6">{tour.excerpt}</p>}

    {tour.content?.length ? (
      <div class="prose prose-lg max-w-none mt-8">
          <PortableTextRenderer value={tour.content} />
      </div>
    ) : (
      <p class="text-navy/80 mt-8">Описание скоро будет.</p>
    )}

    {reviewCount > 0 && (
      <section aria-labelledby="reviews-heading" class="mt-12 border-t border-navy/10 pt-8">
        <h2 id="reviews-heading" class="text-2xl font-semibold text-navy">
          Отзывы
        </h2>
        <p class="mt-2 text-sm text-navy/80">
          Средняя оценка {visibleAverageRating} · {reviewCount} отзыв(ов)
        </p>

        <ul class="mt-6 divide-y divide-navy/10">
          {approvedTourReviews.map((review) => {
            const formattedDate = formatReviewDate(review.dateISO);
            return (
              <li class="py-5 first:pt-0 last:pb-0">
                <p class="text-base font-medium text-navy">{review.name}</p>
                <p class="mt-1 text-sm text-navy/80">{renderStars(review.rating)}</p>
                <p class="mt-3 text-base leading-7 text-navy/90">{review.text}</p>
                {formattedDate && (
                  <p class="mt-2 text-xs text-navy/60">{formattedDate}</p>
                )}
              </li>
            );
          })}
        </ul>
      </section>
    )}
  </section>
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sanityClient, urlFor } from "../../lib/sanity";
import PortableTextRenderer from "../../components/PortableTextRenderer";


export async function getStaticPaths() {
  const slugs: { slug: { current: string } }[] = await sanityClient.fetch(`
    *[_type == "tour" && defined(slug.current)]{ slug }
  `);

  return slugs.map((t) => ({
    params: { slug: t.slug.current },
  }));
}

type Tour = {
  title: string;
  excerpt?: string;
  heroImage?: any;
  priceFromEur?: number;
  durationHours?: number;
  format?: "walking" | "car" | "mixed";
  content?: any[];
};

const { slug } = Astro.params;

const tour: Tour | null = await sanityClient.fetch(
  `
  *[_type == "tour" && slug.current == $slug][0]{
    title,
    excerpt,
    heroImage,
    priceFromEur,
    durationHours,
    format,
    content
  }
`,
  { slug }
);

if (!tour) {
  return Astro.redirect("/404");
}
---

<BaseLayout>
  <Fragment slot="head">
    <title>{tour.title} — Siiatravel</title>
    {tour.excerpt && <meta name="description" content={tour.excerpt} />}
  </Fragment>

  <section class="max-w-4xl mx-auto px-4 py-16">
    <a href="/tours" class="text-sm text-navy/70 hover:underline">← Все экскурсии</a>

    <h1 class="text-3xl md:text-4xl font-semibold text-navy mt-4">{tour.title}</h1>

    <div class="text-sm text-navy/80 mt-4 flex flex-wrap gap-x-4 gap-y-1">
      {typeof tour.priceFromEur === "number" && (
        <span>
          <strong class="text-navy">от {tour.priceFromEur} €</strong>
        </span>
      )}
      {typeof tour.durationHours === "number" && <span>{tour.durationHours} ч</span>}
      {tour.format && (
        <span>
          {tour.format === "walking"
            ? "пешая"
            : tour.format === "car"
              ? "с машиной"
              : "смешанная"}
        </span>
      )}
    </div>

    {tour.heroImage && (
      <img
        src={urlFor(tour.heroImage).width(1200).height(700).fit("crop").url()}
        alt={tour.title}
        loading="eager"
        class="w-full rounded-2xl mt-8 object-cover"
      />
    )}

    {tour.excerpt && <p class="text-navy/80 text-lg mt-6">{tour.excerpt}</p>}

    {tour.content?.length ? (
      <div class="prose prose-lg max-w-none mt-8">
          <PortableTextRenderer value={tour.content} />
      </div>
    ) : (
      <p class="text-navy/80 mt-8">Описание скоро будет.</p>
    )}
  </section>
</BaseLayout>

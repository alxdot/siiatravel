---
import BaseLayout from "../layouts/BaseLayout.astro";
import ReviewForm from "../components/reviews/ReviewForm.astro";
import { sanityClient } from "../lib/sanity";

type ReviewPreview = {
  name: string;
  rating?: unknown;
  text: string;
  date?: string;
};

const latestReviews: ReviewPreview[] = await sanityClient.fetch(`
  *[_type == "review" && status == "approved"] | order(date desc)[0...3] {
    name,
    rating,
    text,
    date
  }
`);

const safeRating = (value: unknown) => {
  const numeric = typeof value === "number" ? value : Number(value);
  const integer = Number.isFinite(numeric) ? Math.trunc(numeric) : 1;
  return Math.min(5, Math.max(1, integer));
};

const stars = (rating: number) => `${"★".repeat(rating)}${"☆".repeat(5 - rating)}`;

const formatRuDate = (value?: string) => {
  if (!value) return "";
  const parsed = new Date(value);
  if (Number.isNaN(parsed.getTime())) return "";
  return parsed.toLocaleDateString("ru-RU");
};

const previewText = (value: string, maxLength = 180) => {
  const trimmed = value.trim();
  if (trimmed.length <= maxLength) return trimmed;
  return `${trimmed.slice(0, maxLength).trimEnd()}…`;
};
---

<BaseLayout>
  <Fragment slot="title">Экскурсии и услуги в Стамбуле — Siiatravel</Fragment>

  <section class="max-w-6xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-semibold text-navy mb-5">
      Экскурсии и услуги в Стамбуле
    </h1>

    <p class="text-lg text-navy/80 mb-8 max-w-2xl">
      Частные экскурсии, яхты по Босфору, трансферы и услуги переводчика. Быстро отвечаем, работаем по вашему запросу.
    </p>

    <div class="flex flex-col sm:flex-row gap-3">
      <a href="#" class="bg-primary text-white px-6 py-3 rounded-lg font-medium hover:opacity-90">
        Написать в WhatsApp
      </a>
      <a href="/contacts" class="border border-navy/20 px-6 py-3 rounded-lg font-medium hover:bg-black/5">
        Оставить заявку
      </a>
    </div>
  </section>

  <section class="my-12">
    {latestReviews.length > 0 && (
      <div class="mx-auto mb-10 max-w-6xl px-4">
        <h2 class="mb-5 text-2xl font-semibold text-slate-900">Последние отзывы</h2>
        <ul class="grid gap-4 md:grid-cols-3">
          {latestReviews.map((review) => {
            const rating = safeRating(review.rating);

            return (
              <li class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                <p class="text-lg leading-none text-amber-500" aria-label={`Оценка: ${rating} из 5`}>
                  {stars(rating)}
                </p>
                <h3 class="mt-3 text-base font-semibold text-slate-900">{review.name}</h3>
                <p class="mt-2 text-sm text-slate-700">{previewText(review.text)}</p>
                <p class="mt-3 text-sm text-slate-600">{formatRuDate(review.date)}</p>
              </li>
            );
          })}
        </ul>
      </div>
    )}

    <ReviewForm />
    <div class="mt-6 text-center">
      <a
        href="/reviews"
        class="text-sm font-medium text-slate-900 underline underline-offset-4 hover:text-slate-700"
      >
        Все отзывы →
      </a>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout>
  <Fragment slot="head">
    <title>Яхты по Босфору — Siiatravel</title>
    <meta name="description" content="Прогулки на моторных яхтах по Босфору: варианты, формат, цена за час (минимум 2 часа). Быстро отвечаем." />
  </Fragment>

  <section class="max-w-6xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-semibold text-navy mb-4">Яхты по Босфору</h1>
    <p class="text-navy/80 max-w-2xl">
      Страница-заготовка. На этапе Sanity сюда подтянем 17 страниц яхт и сделаем список.
    </p>
  </section>
</BaseLayout>

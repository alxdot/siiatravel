---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <Fragment slot="head">
    <title>Контакты — Siiatravel</title>
    <meta name="description" content="Связаться с нами: WhatsApp, телефон и форма заявки." />
  </Fragment>

  <section class="max-w-6xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-semibold text-navy mb-6">Контакты</h1>

    <div class="grid gap-6 md:grid-cols-2">
      <div class="p-6 border border-black/10 rounded-xl">
        <h2 class="text-xl font-semibold mb-3">WhatsApp</h2>
        <p class="text-navy/80 mb-4">Ссылка пока заглушка. Номер добавим позже.</p>
        <a href="#" class="bg-primary text-white px-4 py-2 rounded-lg inline-block">
          Написать в WhatsApp
        </a>
      </div>

      <div class="p-6 border border-black/10 rounded-xl">
        <h2 class="text-xl font-semibold mb-3">Телефон</h2>
        <p class="text-navy/80 mb-2">+90 XXX XXX XX XX</p>
        <a class="underline hover:opacity-80" href="tel:+900000000000">Позвонить</a>
      </div>
    </div>

    <div class="mt-8 p-6 border border-black/10 rounded-xl">
      <h2 class="text-xl font-semibold mb-3">Форма заявки</h2>
      <p class="text-navy/80">Пока заглушка. Реальную форму сделаем позже (M4/M5).</p>
    </div>
  </section>
</BaseLayout>
